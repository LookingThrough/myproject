        ]
  )

  return (completion.choices[0].message.content)

def latex_to_plain(text: str) -> str:
    lines = text.splitlines()
    processed_lines = []

    math_commands = {
        r'\sin': 'sin',
        r'\cos': 'cos',
        r'\tan': 'tan',
        r'\cot': 'cot',
        r'\sec': 'sec',
        r'\csc': 'csc',
        r'\arcsin': 'arcsin',
        r'\arccos': 'arccos',
        r'\arctan': 'arctan',
        r'\sinh': 'sinh',
        r'\cosh': 'cosh',
        r'\tanh': 'tanh',
        r'\log': 'log',
        r'\ln': 'ln',
        r'\lg': 'lg',
        r'\exp': 'exp',
        r'\det': 'det',
        r'\lim': 'lim',
        r'\max': 'max',
        r'\min': 'min',
    }

    for line in lines:
        line = re.sub(r'\\frac\{([^{}]+)\}\{([^{}]+)\}', r'\1/\2', line)   
        line = re.sub(r'\\boxed\{([^{}]+)\}', r'\1', line)                 
        line = re.sub(r'\\text\{([^{}]*)\}', r'\1', line)                  
        line = line.replace(r'\cdot', '*')                                 
        line = line.replace(r'\Rightarrow', '→')                           
        line = re.sub(r'\\[,;:]', '', line) 
        line = re.sub(r'{', '', line)
        line = re.sub(r'}', '', line)
        line = line.replace(r'[', '')
        line = line.replace(r']', '')                         

        
        for cmd, replacement in math_commands.items():
            line = line.replace(cmd, replacement)

        line = re.sub(r'\\([a-zA-Z]+)', '', line)
        line = line.replace('\\', '')
        line = re.sub(r'[ \t]+', ' ', line).strip()
        processed_lines.append(line)

    return '\n'.join(processed_lines)
    

